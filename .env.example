# ==============================================
# tech-collect 環境設定
# ==============================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# --- LLM Provider ---
# ollama / openai / claude から選択
LLM_PROVIDER=ollama

# --- Ollama (ローカルLLM・無料) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- OpenAI (オプション) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude (オプション) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Notion API ---
NOTION_API_KEY=
NOTION_DATABASE_ID=          # ALLデータベースID（全記事蓄積）
NOTION_DAILY_PAGE_ID=        # Dailyページの親ページID（日別レポート）

# --- Qiita API (オプション: レート制限緩和) ---
# https://qiita.com/settings/tokens で取得
QIITA_ACCESS_TOKEN=

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma
